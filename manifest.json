{
   "manifest_version": 3,
   "name": "RD Manager",
   "version": "1.0.1",
   "description": "Gerencie todos os seus downloads do Real-Debrid em uma janela simples.",
   "browser_specific_settings": {
      "gecko": {
         "id": "rd-manager@seu-dominio.com",
         "strict_min_version": "109.0"
      }
   },
   "permissions": [ "storage", "contextMenus", "alarms" ],
   "host_permissions": [ "https://api.real-debrid.com/*" ],
   "background": {
      "scripts": ["background.js"]
   },
   "action": {
      "default_icon": {
         "16": "icons/icon16.png",
         "32": "icons/icon32.png",
         "48": "icons/icon48.png",
         "128": "icons/icon128.png"
      },
      "default_popup": "popup.html"
   },
   "icons": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
   }
}
