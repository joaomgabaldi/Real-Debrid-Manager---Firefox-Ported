{
   "manifest_version": 3,
   "name": "RD Manager",
   "version": "1.0.1",
   "description": "Gerencie todos os seus downloads do Real-Debrid em uma janela simples.",
   "browser_specific_settings": {
      "gecko": {
         "id": "{4b8c9d1e-2f3a-4e5d-b6c7-8a9b0c1d2e3f}",
         "strict_min_version": "109.0",
		 "data_collection_permissions": {
            "required": ["none"]
		 }
      }
   },
   "permissions": [ "storage", "contextMenus", "alarms" ],
   "host_permissions": [ "https://api.real-debrid.com/*" ],
   "background": {
      "scripts": ["background.js"]
   },
   "action": {
      "default_icon": {
         "16": "icons/icon16.png",
         "32": "icons/icon32.png",
         "48": "icons/icon48.png",
         "128": "icons/icon128.png"
      },
      "default_popup": "popup.html"
   },
   "icons": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
   }
}
